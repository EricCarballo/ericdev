---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero';
import Skills from '@/components/Skills';
import Projects from '@/components/Projects';
import Optimizations from '@/components/Optimizations';
import About from '@/components/About';
import Footer from '@/components/Footer';
import { useTranslations } from '@/i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
---

<BaseLayout lang={lang}>
  <main id="main-content">
    <Hero
      client:visible
      copy={{
        ...t.hero,
        skills: {
          categories: t.skills.categories,
          hardSkillsLabel: t.skills.hardSkillsLabel,
        },
        cv: t.cv,
      }}
      email={t.profile.email}
    />
    <Skills
      client:visible
      copy={{
        skills: t.skills,
        profile: {
          email: t.profile.email,
          linkedin: t.profile.linkedin,
        },
        experience: t.experience,
        education: t.education,
        certifications: t.certifications,
        methodologies: t.methodologies,
        metrics: t.metrics,
      }}
    />
    <Projects
      client:load
      copy={{ projects: t.projects }}
    />
    <Optimizations client:idle copy={t.lighthouse} />
    <About
      client:visible
      copy={{ about: t.about, profile: t.profile }}
    />
  </main>
  <Footer
    client:idle
    copy={{
      footer: t.footer,
      lighthouse: t.lighthouse,
      profile: {
        email: t.profile.email,
        linkedin: t.profile.linkedin,
      },
    }}
  />
</BaseLayout>
