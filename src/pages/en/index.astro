---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero';
import Skills from '@/components/Skills';
import Projects from '@/components/Projects';
import Optimizations from '@/components/Optimizations';
import About from '@/components/About';
import Footer from '@/components/Footer';
import { buildPageCopy } from '@/i18n/page-copy';
import { useTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const page = buildPageCopy(t);
---

<BaseLayout lang={lang}>
  <main id="main-content">
    <Hero client:visible copy={page.hero} email={page.email} />
    <Skills client:visible copy={page.skills} />
    <Projects client:visible copy={page.projects} />
    <Optimizations client:idle copy={page.lighthouse} />
    <About client:visible copy={page.about} />
  </main>
  <Footer client:idle copy={page.footer} />
</BaseLayout>
